[Desktop Entry]
Name=cbar
Comment=Scriptable COSMIC panel applet
Type=Application
Exec=__CBAR_EXEC__
Terminal=false
Categories=Utility;
Keywords=COSMIC;Applet;plugins;scripts;panel;
Icon=io.github.alexprates.CBar-symbolic
StartupNotify=true
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
